FROM ubuntu:26.04
USER root:root
ENV TZ="Europe/Helsinki"
RUN apt-get -y update
RUN DEBIAN_FRONTEND=noninteractive apt-get -y upgrade
RUN apt-get -y install ca-certificates tzdata
COPY ./heartbeat_checker /usr/bin/
COPY ./Loudness_Correction_Settings.json /etc/
RUN chmod 755 /usr/bin/heartbeat_checker ; chmod 644 /etc/Loudness_Correction_Settings.json
CMD ["/usr/bin/heartbeat_checker", "-configfile", "/etc/Loudness_Correction_Settings.json"]
